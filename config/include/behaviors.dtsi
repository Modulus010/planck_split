/*
 * Planck Split - Custom Behaviors
 *
 * SPDX-License-Identifier: MIT
 *
 * Hold-tap behaviors for home row mods and layer access.
 * Extracted from planck.keymap for modularity.
 */

#include "layers.h"

#define U_TAPPING_TERM 200

/ {
    behaviors {
        /*
         * um: hold for modifier, tap for keypress
         * Used for home row mods (e.g., &um LGUI A)
         */
        um: um {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <U_TAPPING_TERM>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;
        };

        /*
         * ul: hold for layer, tap for keypress
         * Used for thumb cluster layer access (e.g., &ul NAV SPACE)
         */
        ul: ul {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <U_TAPPING_TERM>;
            flavor = "tap-preferred";
            bindings = <&mo>, <&kp>;
        };
    };
};
