/*
 * Planck Split - Macros
 *
 * SPDX-License-Identifier: MIT
 *
 * Miryoku-inspired shift-function macros and BT profile selectors.
 * Extracted from planck.keymap for modularity.
 */

/* Generic macro definition helper */
#define U_MACRO(name,...) \
/ { \
    macros { \
        name: name { \
            compatible = "zmk,behavior-macro"; \
            #binding-cells = <0>; \
            __VA_ARGS__ \
        }; \
    }; \
};

/*
 * MIRYOKU_SHIFT_FUNCTION: Mod-morph behavior
 * Normal press = BINDING, shifted press = SHIFT_BINDING
 */
#define MIRYOKU_SHIFT_FUNCTION(NAME, BINDING, SHIFT_BINDING) \
/ { \
    behaviors { \
        NAME: NAME { \
            compatible = "zmk,behavior-mod-morph"; \
            #binding-cells = <0>; \
            bindings = <BINDING>, <SHIFT_BINDING>; \
            mods = <(MOD_LSFT|MOD_RSFT)>; \
        }; \
    }; \
};

/*
 * MIRYOKU_SHIFT_MACRO: Combines a macro + mod-morph
 * Normal press = BINDING, shifted press = executes SHIFT_BINDING via macro
 * Used for BT profile selection with shift-to-clear pattern.
 */
#define MIRYOKU_SHIFT_MACRO(NAME, BINDING, SHIFT_BINDING) \
U_MACRO(u_macro_ ## NAME, wait-ms = <0>; bindings = <SHIFT_BINDING>;) \
MIRYOKU_SHIFT_FUNCTION(NAME, BINDING, &u_macro_ ## NAME)

/*
 * Bluetooth profile selectors
 * Tap = select profile, Shift+tap = select + clear profile
 */
MIRYOKU_SHIFT_MACRO(u_bt_sel_0, &bt BT_SEL 0, &bt BT_SEL 0 &bt BT_CLR)
MIRYOKU_SHIFT_MACRO(u_bt_sel_1, &bt BT_SEL 1, &bt BT_SEL 1 &bt BT_CLR)
MIRYOKU_SHIFT_MACRO(u_bt_sel_2, &bt BT_SEL 2, &bt BT_SEL 2 &bt BT_CLR)
MIRYOKU_SHIFT_MACRO(u_bt_sel_3, &bt BT_SEL 3, &bt BT_SEL 3 &bt BT_CLR)
MIRYOKU_SHIFT_MACRO(u_bt_sel_4, &bt BT_SEL 4, &bt BT_SEL 4 &bt BT_CLR)
