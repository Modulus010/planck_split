# SPDX-License-Identifier: MIT
# Planck Split Left (Central) - nRF52840

#
# Clock - 使用内部 RC 振荡器并启用校准
#
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC_CALIBRATION=y

#
# ZMK Core
#
CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y

#
# Split Keyboard - Central 需要设置 BT 连接数
# BT_MAX_CONN = 外围设备数(1) + 蓝牙配置文件数(5) = 6
#
CONFIG_BT_MAX_CONN=6
CONFIG_BT_MAX_PAIRED=6

#
# Build / Flash
#
CONFIG_BUILD_OUTPUT_UF2=y
CONFIG_USE_DT_CODE_PARTITION=y

#
# PWM / LED (hardware capability)
#
CONFIG_PWM=y
CONFIG_LED=y
CONFIG_LED_PWM=y

#
# ZMK Studio
#
CONFIG_ZMK_STUDIO=y
CONFIG_ZMK_STUDIO_LOCKING=n
